{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Flutter: Run Windows",
      "type": "shell",
      "command": "flutter",
      "args": ["run", "-d", "windows"],
      "group": { "kind": "build", "isDefault": true },
      "problemMatcher": []
    },
    {
      "label": "Flutter: Build Windows (release)",
      "type": "shell",
      "command": "flutter",
      "args": ["build", "windows", "--release"],
      "group": "build",
      "problemMatcher": []
    },
    {
      "label": "Flutter: Run Android",
      "type": "shell",
      "command": "flutter",
      "args": ["run", "-d", "android"],
      "group": "build",
      "problemMatcher": []
    },
    {
      "label": "Flutter: Analyze",
      "type": "shell",
      "command": "flutter",
      "args": ["analyze"],
      "group": "test",
      "problemMatcher": []
    },
    {
      "label": "Flutter: Test",
      "type": "shell",
      "command": "flutter",
      "args": ["test"],
      "group": "test",
      "problemMatcher": []
    },
    {
      "label": "Riverpod: generate (build_runner)",
      "type": "shell",
      "command": "flutter",
      "args": ["pub", "run", "build_runner", "build", "--delete-conflicting-outputs"],
      "group": "build",
      "problemMatcher": []
    }
  ]
}
